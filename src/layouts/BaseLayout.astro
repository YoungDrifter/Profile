---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Academic resume website for Yuhang Yang."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://yuhangyang.site/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <script is:inline>
      const root = document.documentElement;
      const preferred = localStorage.getItem("site-language") || "en";
      const main = document.querySelector("[data-scroll-main]");
      const sections = Array.from(document.querySelectorAll(".sec[id]"));
      const links = Array.from(document.querySelectorAll("[data-section-link][href^='#']"));
      const topnav = document.querySelector(".topnav");
      const mobileNav = document.querySelector(".mobile-nav");
      const mobileTrigger = document.querySelector("[data-mobile-nav-trigger]");
      const mobileMenu = document.querySelector("[data-mobile-nav-menu]");
      const mobileCurrent = document.querySelector("[data-mobile-nav-current]");
      let currentSection = sections[0]?.id || "about";

      const updateMobileLabel = () => {
        const activeLink = document.querySelector(`.mobile-nav-link[href="#${currentSection}"]`);
        if (!activeLink || !mobileCurrent) return;
        const language = root.dataset.lang === "zh" ? "zh" : "en";
        mobileCurrent.textContent = activeLink.dataset[language === "zh" ? "labelZh" : "labelEn"];
      };

      const setLanguage = (language) => {
        const next = language === "zh" ? "zh" : "en";
        root.dataset.lang = next;
        root.lang = next === "zh" ? "zh-CN" : "en";
        localStorage.setItem("site-language", next);
        document.querySelectorAll("[data-language-button]").forEach((button) => {
          const active = button.dataset.languageButton === next;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-pressed", active ? "true" : "false");
        });
        updateMobileLabel();
      };

      setLanguage(preferred);

      const closeMobileMenu = ({ restoreFocus = false } = {}) => {
        if (!mobileTrigger || !mobileMenu) return;
        mobileTrigger.setAttribute("aria-expanded", "false");
        mobileNav?.classList.remove("is-open");
        mobileMenu.hidden = true;
        if (restoreFocus) mobileTrigger.focus();
      };

      const openMobileMenu = () => {
        if (!mobileTrigger || !mobileMenu) return;
        mobileTrigger.setAttribute("aria-expanded", "true");
        mobileNav?.classList.add("is-open");
        mobileMenu.hidden = false;
      };

      mobileTrigger?.addEventListener("click", () => {
        if (mobileTrigger.getAttribute("aria-expanded") === "true") closeMobileMenu();
        else openMobileMenu();
      });

      document.addEventListener("click", (event) => {
        const languageButton = event.target.closest("[data-language-button]");
        if (languageButton) setLanguage(languageButton.dataset.languageButton);
        if (mobileNav && !mobileNav.contains(event.target)) closeMobileMenu();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && mobileTrigger?.getAttribute("aria-expanded") === "true") {
          closeMobileMenu({ restoreFocus: true });
        }
      });

      if (main && sections.length && links.length) {
        const usesMainScroll = () => getComputedStyle(main).overflowY !== "visible" && main.scrollHeight > main.clientHeight;
        const stickyHeight = () => {
          if (mobileNav && getComputedStyle(mobileNav).display !== "none") return mobileNav.offsetHeight;
          return topnav?.offsetHeight || 0;
        };

        const getSectionTop = (section) => {
          if (usesMainScroll()) return section.offsetTop;
          return section.getBoundingClientRect().top + window.scrollY;
        };

        const setActiveSection = () => {
          const top = usesMainScroll()
            ? main.scrollTop + 72
            : window.scrollY + stickyHeight() + 120;
          let current = sections[0].id;
          sections.forEach((section) => {
            if (getSectionTop(section) <= top) current = section.id;
          });
          currentSection = current;
          links.forEach((link) => {
            const active = link.getAttribute("href") === `#${current}`;
            link.classList.toggle("active", active);
            if (link.classList.contains("mobile-nav-link")) {
              if (active) link.setAttribute("aria-current", "location");
              else link.removeAttribute("aria-current");
            }
          });
          updateMobileLabel();
        };

        main.addEventListener("scroll", setActiveSection, { passive: true });
        window.addEventListener("scroll", setActiveSection, { passive: true });
        window.addEventListener("resize", setActiveSection);
        links.forEach((link) => {
          link.addEventListener("click", (event) => {
            const target = document.querySelector(link.getAttribute("href"));
            if (!target) return;
            event.preventDefault();
            closeMobileMenu();
            if (usesMainScroll()) {
              main.scrollTo({ top: target.offsetTop - 10, behavior: "smooth" });
            } else {
              window.scrollTo({
                top: target.getBoundingClientRect().top + window.scrollY - stickyHeight() - 10,
                behavior: "smooth"
              });
            }
            window.history.replaceState(null, "", link.getAttribute("href"));
            currentSection = target.id;
            links.forEach((sectionLink) => {
              const active = sectionLink.getAttribute("href") === `#${currentSection}`;
              sectionLink.classList.toggle("active", active);
              if (sectionLink.classList.contains("mobile-nav-link")) {
                if (active) sectionLink.setAttribute("aria-current", "location");
                else sectionLink.removeAttribute("aria-current");
              }
            });
            updateMobileLabel();
          });
        });
        setActiveSection();
      }
    </script>
  </body>
</html>
