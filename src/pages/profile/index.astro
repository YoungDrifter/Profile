---
import Sidebar from "../../components/Sidebar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { competitions, education, honors, internships, profile, projects, publications } from "../../data/profile";

const navItems = [
  { href: "#about", en: "About", zh: "关于" },
  { href: "#education", en: "Education", zh: "教育" },
  { href: "#internships", en: "Internships", zh: "实习" },
  { href: "#projects", en: "Projects", zh: "项目" },
  { href: "#publications", en: "Publications", zh: "论文" },
  { href: "#competitions", en: "Competitions", zh: "竞赛经历" },
  { href: "#honors", en: "Honors", zh: "荣誉奖项" }
];
const localizePeriod = (period: string) => period.replace("Present", "现在");
---

<BaseLayout title={`${profile.name} | Profile`} description={profile.intro.en}>
  <div class="shell">
    <Sidebar />

    <main class="main" id="main" data-scroll-main>
      <nav class="topnav" aria-label="Profile sections">
        {
          navItems.map((item, index) => (
            <a class:list={["tnav-link", index === 0 && "active"]} href={item.href} data-section-link>
              <span data-locale="en">{item.en}</span>
              <span data-locale="zh">{item.zh}</span>
            </a>
          ))
        }
      </nav>

      <nav class="mobile-nav" aria-label="Profile sections">
        <button class="mobile-nav-trigger" type="button" aria-expanded="false" aria-controls="mobile-section-menu" data-mobile-nav-trigger>
          <span class="mobile-nav-kicker">
            <span data-locale="en">Section</span>
            <span data-locale="zh">页面导航</span>
          </span>
          <span class="mobile-nav-current" data-mobile-nav-current>About</span>
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="m6 8 4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="mobile-nav-menu" id="mobile-section-menu" hidden data-mobile-nav-menu>
          {
            navItems.map((item, index) => (
              <a
                class:list={["mobile-nav-link", index === 0 && "active"]}
                href={item.href}
                data-section-link
                data-label-en={item.en}
                data-label-zh={item.zh}
                aria-current={index === 0 ? "location" : undefined}
              >
                <span data-locale="en">{item.en}</span>
                <span data-locale="zh">{item.zh}</span>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="m7.5 4.5 5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ))
          }
        </div>
      </nav>

      <div class="body">
        <section class="sec" id="about">
          <div class="sec-h">
            <span data-locale="en">About</span>
            <span data-locale="zh">关于</span>
          </div>
          <p class="about-p">
            <span data-locale="en">{profile.intro.en}</span>
            <span data-locale="zh">{profile.intro.zh}</span>
          </p>
          <div class="tags">
            {
              profile.interests.map((interest) => (
                <span class="tag">
                  <span data-locale="en">{interest.en}</span>
                  <span data-locale="zh">{interest.zh}</span>
                </span>
              ))
            }
          </div>
        </section>

        <section class="sec" id="education">
          <div class="sec-h">
            <span data-locale="en">Education</span>
            <span data-locale="zh">教育经历</span>
          </div>
          <div class="tl">
            {
              education.map((item, index) => (
                <div class="tl-row">
                  <div class="tl-spine">
                    <div class:list={["dot", index > 0 && "dot-dim"]}></div>
                    {index < education.length - 1 && <div class="spine-line"></div>}
                  </div>
                  <div class="tl-card">
                    <div class="tl-period">
                      <span data-locale="en">{item.period}</span>
                      <span data-locale="zh">{localizePeriod(item.period)}</span>
                    </div>
                    <div class="tl-title">
                      <span data-locale="en">{item.title.en}</span>
                      <span data-locale="zh">{item.title.zh}</span>
                    </div>
                    <div class="tl-inst">
                      <span data-locale="en">{item.subtitle.en}</span>
                      <span data-locale="zh">{item.subtitle.zh}</span>
                    </div>
                    {item.description.en && (
                      <div class="tl-desc">
                        <span data-locale="en">{item.description.en}</span>
                        <span data-locale="zh">{item.description.zh}</span>
                      </div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <section class="sec" id="internships">
          <div class="sec-h">
            <span data-locale="en">Internships</span>
            <span data-locale="zh">实习经历</span>
          </div>
          <div class="tl">
            {
              internships.map((item, index) => (
                <div class="tl-row">
                  <div class="tl-spine">
                    <div class:list={["dot", index > 0 && "dot-dim"]}></div>
                    {index < internships.length - 1 && <div class="spine-line"></div>}
                  </div>
                  <div class="tl-card">
                    <div class="tl-period">
                      <span data-locale="en">{item.period}</span>
                      <span data-locale="zh">{localizePeriod(item.period)}</span>
                    </div>
                    <div class="tl-title">
                      <span data-locale="en">{item.title.en}</span>
                      <span data-locale="zh">{item.title.zh}</span>
                    </div>
                    <div class="tl-inst">
                      <span data-locale="en">{item.subtitle.en}</span>
                      <span data-locale="zh">{item.subtitle.zh}</span>
                    </div>
                    <div class="tl-desc">
                      <span data-locale="en">{item.description.en}</span>
                      <span data-locale="zh">{item.description.zh}</span>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <section class="sec" id="projects">
          <div class="sec-h">
            <span data-locale="en">Projects</span>
            <span data-locale="zh">项目</span>
          </div>
          {
            projects.map((project) => (
              <div class="pub-card">
                <div class="pub-title">
                  <span data-locale="en">{project.title.en}</span>
                  <span data-locale="zh">{project.title.zh}</span>
                </div>
                <div class="pub-meta">
                  <span data-locale="en">{project.role.en}</span>
                  <span data-locale="zh">{project.role.zh}</span>
                  <span> · </span>
                  <span data-locale="en">{project.period}</span>
                  <span data-locale="zh">{localizePeriod(project.period)}</span>
                </div>
                <p class="pub-summary">
                  <span data-locale="en">{project.summary.en}</span>
                  <span data-locale="zh">{project.summary.zh}</span>
                </p>
              </div>
            ))
          }
        </section>

        <section class="sec" id="publications">
          <div class="sec-h">
            <span data-locale="en">Publications</span>
            <span data-locale="zh">论文</span>
          </div>
          {
            publications.map((publication) => (
              <div class="pub-card">
                <div class="pub-title">
                  <span data-locale="en">{publication.title.en}</span>
                  <span data-locale="zh">{publication.title.zh}</span>
                </div>
                <div class="pub-meta">
                  {publication.authors}
                  <span> · </span>
                  <span data-locale="en">{publication.venue.en}</span>
                  <span data-locale="zh">{publication.venue.zh}</span>
                  <span> · </span>
                  {publication.year}
                </div>
                <p class="pub-summary">
                  <span data-locale="en">{publication.summary.en}</span>
                  <span data-locale="zh">{publication.summary.zh}</span>
                </p>
                {publication.pdf && (
                  <div class="pub-actions">
                    <a class="pub-pdf" href={publication.pdf} target="_blank" rel="noopener noreferrer">
                      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M6.75 3.75h7.5l3 3v13.5h-10.5V3.75Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                        <path d="M14.25 3.75v3h3M9.25 15.5h5.5M9.25 12.5h5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                      </svg>
                      PDF
                    </a>
                  </div>
                )}
              </div>
            ))
          }
        </section>

        <section class="sec" id="competitions">
          <div class="sec-h">
            <span data-locale="en">Competitions</span>
            <span data-locale="zh">竞赛经历</span>
          </div>
          <div class="award-list">
            {
              competitions.map((item) => (
                <div class="award-item">
                  <div class="award-yr">{item.period}</div>
                  <div class="award-main">
                    <div class="award-name">
                      <span data-locale="en">{item.title.en}</span>
                      <span data-locale="zh">{item.title.zh}</span>
                    </div>
                    <div class="award-org">
                      <span data-locale="en">{item.subtitle.en}</span>
                      <span data-locale="zh">{item.subtitle.zh}</span>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <section class="sec" id="honors">
          <div class="sec-h">
            <span data-locale="en">Honors</span>
            <span data-locale="zh">荣誉奖项</span>
          </div>
          <div class="award-list">
            {
              honors.map((item) => (
                <div class="award-item">
                  <div class="award-yr">{item.period}</div>
                  <div class="award-main">
                    <div class="award-name">
                      <span data-locale="en">{item.title.en}</span>
                      <span data-locale="zh">{item.title.zh}</span>
                    </div>
                    <div class="award-org">
                      <span data-locale="en">{item.subtitle.en}</span>
                      <span data-locale="zh">{item.subtitle.zh}</span>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
