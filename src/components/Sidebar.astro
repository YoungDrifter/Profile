---
import { siGithub, siX, siXiaohongshu, siZhihu } from "simple-icons";
import { profile } from "../data/profile";

const mailHref = `mailto:${profile.email}`;
const brandIcons = {
  github: siGithub,
  x: siX,
  zhihu: siZhihu,
  xiaohongshu: siXiaohongshu
};

const getBrandIcon = (item: { label: string; url: string }) => {
  if (item.url.includes("github.com")) return brandIcons.github;
  if (item.url.includes("x.com")) return brandIcons.x;
  if (item.url.includes("zhihu.com")) return brandIcons.zhihu;
  return brandIcons.xiaohongshu;
};
---

<aside class="sidebar">
  <a class="avatar" href="/profile/" aria-label="Yuhang Yang profile">
    <img src={profile.avatar} alt={profile.displayName.en} />
  </a>
  <div class="s-name">
    <span data-locale="en">{profile.displayName.en}</span>
    <span data-locale="zh">{profile.displayName.zh}</span>
  </div>
  <div class="s-sub">
    <span data-locale="en">Undergraduate Student<br />School of Mathematics<br />Nanjing University</span>
    <span data-locale="zh">数学专业本科生<br />南京大学<br />数学学院</span>
  </div>

  <div class="s-divider"></div>

  <div class="s-cap">
    <span data-locale="en">Info</span>
    <span data-locale="zh">信息</span>
  </div>
  <div class="s-meta">
    <div class="s-row">
      <svg fill="none" viewBox="0 0 24 24" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"/></svg>
      <span data-locale="en">{profile.location.en}</span>
      <span data-locale="zh">{profile.location.zh}</span>
    </div>
    <a class="s-row" href={mailHref}>
      <svg fill="none" viewBox="0 0 24 24" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
      {profile.email}
    </a>
    <div class="s-row">
      <svg fill="none" viewBox="0 0 24 24" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 0 0-.491 6.347A48.627 48.627 0 0 1 12 20.904a48.627 48.627 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.57 50.57 0 0 0-2.658-.813A59.905 59.905 0 0 1 12 3.493a59.902 59.902 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>
      <span data-locale="en">2024 - Present</span>
      <span data-locale="zh">2024 - 现在</span>
    </div>
  </div>

  <div class="s-cap">
    <span data-locale="en">Links</span>
    <span data-locale="zh">链接</span>
  </div>
  <div class="s-links">
    {profile.socials.map((item) => (
      <a class="s-link" href={item.url} target="_blank" rel="noreferrer">
        <svg class="brand-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d={getBrandIcon(item).path}></path>
        </svg>
        {item.label}
      </a>
    ))}
  </div>

  <div class="language-switch" aria-label="Language switch">
    <button class="is-active" type="button" data-language-button="en" aria-pressed="true">EN</button>
    <button type="button" data-language-button="zh" aria-pressed="false">中文</button>
  </div>

  <a class="cv-btn" href={profile.cv} download>
    <svg fill="none" viewBox="0 0 24 24" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
    <span data-locale="en">Download CV</span>
    <span data-locale="zh">下载简历</span>
  </a>
</aside>
